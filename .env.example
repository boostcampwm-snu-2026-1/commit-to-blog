# GitHub Personal Access Token (scopes: repo, read:user)
# https://github.com/settings/tokens
GITHUB_TOKEN=

# Anthropic API key
# https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Target repo for "발행하기" (owner/repo). Required for publish endpoint.
BLOG_REPO=

# Express server port (default 3001)
PORT=3001
