# Copy this file to `.env` and fill in real values.
# `.env` is gitignored — never commit secrets.

# GitHub Personal Access Token (classic) with `repo` and `read:user` scopes.
# Generate at: https://github.com/settings/tokens
GITHUB_TOKEN=

# OpenAI API key with chat.completions access.
# Generate at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Optional: override OpenAI model (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# Server port (default: 4000)
PORT=4000

# Vite dev server proxy target — points to the Express server
VITE_API_BASE_URL=http://localhost:4000

# Posts 영속화 디렉토리 (apps/server cwd 기준 상대경로). 기본값으로 레포 루트의 data/ 사용.
# DATA_DIR=../../data
