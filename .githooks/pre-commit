#!/usr/bin/env sh
set -eu

echo "Running backend quality gate..."
if [ -d backend ]; then
  (
    cd backend
    uv run ruff check .
    uv run ruff format --check .
  )
fi

echo "Running frontend quality gate..."
if [ -d frontend ]; then
  (
    cd frontend
    npm run lint
    npm run typecheck
  )
fi

echo "Pre-commit quality gate passed."
